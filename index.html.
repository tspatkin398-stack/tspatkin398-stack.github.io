<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Мягкая кровля — Сергей, профессиональный кровельщик</title>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Montserrat:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #1c1f22;
  --bg2:     #232629;
  --bg3:     #2a2e33;
  --card:    #2f3338;
  --border:  #3a3f46;
  --red:     #d42b2b;
  --red2:    #b02020;
  --red3:    rgba(212,43,43,0.15);
  --white:   #ffffff;
  --off:     #e8eaec;
  --silver:  #b0b8c1;
  --muted:   #788090;
}

*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Montserrat',sans-serif;background:var(--bg);color:var(--white);overflow-x:hidden;}

/* NAV */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  background:rgba(20,22,25,0.96);backdrop-filter:blur(12px);
  border-bottom:2px solid var(--red);height:68px;
  display:flex;align-items:center;justify-content:space-between;padding:0 48px;
}
.nav-logo{font-family:'Anton',sans-serif;font-size:1.7rem;letter-spacing:0.12em;color:var(--white);}
.nav-logo em{color:var(--red);font-style:normal;}
.nav-links{display:flex;gap:4px;list-style:none;}
.nav-links a{
  font-size:0.82rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--silver);text-decoration:none;padding:8px 16px;border-radius:2px;transition:all 0.2s;
}
.nav-links a:hover{color:var(--white);background:var(--red3);}

/* HERO */
#hero{
  min-height:100vh;padding-top:68px;
  display:grid;grid-template-columns:1fr 1fr;
  background:linear-gradient(160deg,#111316 0%,#1c1f22 60%);
  overflow:hidden;
}
.hero-left{padding:60px 56px 60px 80px;display:flex;flex-direction:column;justify-content:center;}

.hero-eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  font-size:0.78rem;font-weight:700;letter-spacing:0.22em;
  text-transform:uppercase;color:var(--red);margin-bottom:24px;
}
.hero-eyebrow::before{content:'';width:32px;height:2px;background:var(--red);}

.hero-title{
  font-family:'Anton',sans-serif;
  font-size:clamp(4rem,6.5vw,8rem);
  line-height:0.92;letter-spacing:0.02em;color:var(--white);margin-bottom:8px;
}
.hero-title em{color:var(--red);font-style:normal;display:block;}

.hero-tag{
  display:inline-block;font-size:clamp(1.1rem,1.8vw,1.5rem);font-weight:900;
  letter-spacing:0.18em;text-transform:uppercase;color:var(--white);
  background:var(--red);padding:12px 28px;margin:24px 0 28px;width:fit-content;
  clip-path:polygon(0 0,calc(100% - 12px) 0,100% 100%,12px 100%);
}

.hero-desc{font-size:1.12rem;line-height:1.85;color:var(--silver);max-width:460px;margin-bottom:28px;font-weight:400;}

/* SERGEY INTRO BLOCK */
.hero-intro{
  background:var(--bg3);border:1px solid var(--border);border-left:4px solid var(--red);
  padding:22px 28px;margin-bottom:24px;
}
.hero-intro-text{font-size:1.1rem;font-weight:500;color:var(--off);line-height:1.6;}
.hero-intro-text strong{
  font-family:'Anton',sans-serif;font-size:2.2rem;
  color:var(--red);letter-spacing:0.04em;line-height:1;display:inline;
}

/* CALL BANNER */
.call-banner{
  display:inline-flex;align-items:center;justify-content:center;
  background:var(--red);color:var(--white);
  font-family:'Anton',sans-serif;font-size:3.2rem;letter-spacing:0.16em;
  text-transform:uppercase;text-decoration:none;
  padding:28px 72px;margin-bottom:32px;
  clip-path:polygon(0 0,calc(100% - 18px) 0,100% 100%,18px 100%);
  cursor:pointer;transition:background 0.2s,transform 0.2s;
  border:none;position:relative;overflow:hidden;
  min-width:420px;height:100px;
}
.call-banner:hover{background:var(--red2);transform:scale(1.03);}
.call-label,.call-phone{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  transition:opacity 0.25s,transform 0.25s;
}
.call-phone{opacity:0;transform:scale(0.85);font-size:3rem;letter-spacing:0.1em;}
.call-banner:hover .call-label{opacity:0;transform:scale(1.15);}
.call-banner:hover .call-phone{opacity:1;transform:scale(1);}

.btn-primary{
  display:inline-flex;align-items:center;gap:12px;
  background:transparent;color:var(--white);
  font-size:0.9rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;
  text-decoration:none;padding:16px 36px;
  border:2px solid var(--red);
  transition:background 0.2s,transform 0.2s;width:fit-content;
}
.btn-primary:hover{background:var(--red3);transform:translateY(-2px);}
.btn-primary:hover svg{transform:translateX(5px);}
.btn-primary svg{transition:transform 0.2s;}

/* SLIDER */
.hero-right{position:relative;overflow:hidden;background:#111;}
.slider-wrap{width:100%;height:100%;position:relative;}
.slide{position:absolute;inset:0;opacity:0;transition:opacity 0.7s ease;}
.slide.active{opacity:1;}
.slide img{width:100%;height:100%;object-fit:cover;filter:brightness(0.88) contrast(1.08);}
.slide-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(17,19,22,0.5) 0%,transparent 60%);}
.slider-label{
  position:absolute;bottom:70px;left:20px;
  font-size:0.7rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;
  color:rgba(255,255,255,0.7);background:rgba(0,0,0,0.55);padding:6px 14px;
  border-left:2px solid var(--red);
}
.slider-counter{
  position:absolute;bottom:70px;right:20px;
  font-family:'Anton',sans-serif;font-size:1.1rem;letter-spacing:0.1em;
  color:rgba(255,255,255,0.5);
}
.slider-arrows{position:absolute;bottom:18px;right:20px;display:flex;gap:8px;}
.slider-btn{
  width:48px;height:48px;background:rgba(0,0,0,0.7);
  border:2px solid rgba(255,255,255,0.15);color:var(--white);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all 0.2s;font-size:1.3rem;
}
.slider-btn:hover{background:var(--red);border-color:var(--red);}
.slider-dots{position:absolute;bottom:28px;left:20px;display:flex;gap:8px;}
.dot{width:20px;height:3px;background:rgba(255,255,255,0.2);transition:all 0.3s;cursor:pointer;}
.dot.active{background:var(--red);width:32px;}

/* SECTIONS */
section{padding:90px 80px;}
.sec-label{
  font-size:0.72rem;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;
  color:var(--red);margin-bottom:12px;display:flex;align-items:center;gap:14px;
}
.sec-label::before{content:'';width:32px;height:2px;background:var(--red);}
.sec-title{
  font-family:'Anton',sans-serif;font-size:clamp(3rem,5vw,5.5rem);
  letter-spacing:0.03em;line-height:0.95;color:var(--white);margin-bottom:56px;
}

/* SERVICES */
#services{background:var(--bg2);border-top:1px solid var(--border);}
.services-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border);}
.svc-card{background:var(--card);padding:52px 48px;position:relative;overflow:hidden;transition:background 0.3s;}
.svc-card:hover{background:#353a40;}
.svc-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:3px;
  background:var(--red);transform:scaleX(0);transition:transform 0.4s ease;transform-origin:left;
}
.svc-card:hover::after{transform:scaleX(1);}
.svc-num{
  font-family:'Anton',sans-serif;font-size:6rem;line-height:1;
  color:var(--red);opacity:0.1;position:absolute;top:16px;right:24px;user-select:none;
}
.svc-icon{margin-bottom:22px;}
.svc-icon svg{width:52px;height:52px;}
.svc-title{font-family:'Anton',sans-serif;font-size:2.2rem;letter-spacing:0.04em;color:var(--white);margin-bottom:14px;line-height:1.1;}
.svc-desc{font-size:1.05rem;line-height:1.82;color:var(--silver);font-weight:400;}

/* MATERIALS */
#materials{background:var(--bg);border-top:1px solid var(--border);}
.brand-strip{
  display:flex;align-items:center;gap:20px;
  background:var(--bg3);border:1px solid var(--border);border-left:4px solid var(--red);
  padding:18px 28px;width:fit-content;margin-bottom:40px;
}
.brand-sq{width:44px;height:44px;background:var(--red);display:flex;align-items:center;justify-content:center;font-family:'Anton',sans-serif;font-size:1.1rem;letter-spacing:0.05em;color:var(--white);flex-shrink:0;}
.brand-title{font-family:'Anton',sans-serif;font-size:1.4rem;letter-spacing:0.1em;color:var(--white);}
.brand-sub{font-size:0.72rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);margin-top:3px;}

.roll-scene{
  width:100%;height:220px;background:var(--bg2);border:1px solid var(--border);
  margin-bottom:40px;cursor:pointer;overflow:hidden;position:relative;
}
.roll-svg{position:absolute;top:0;left:0;width:100%;height:100%;}

.mat-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border);}
.mat-card{background:var(--card);padding:36px 32px;border-bottom:3px solid transparent;transition:border-color 0.3s,background 0.3s;display:flex;flex-direction:column;}
.mat-card:hover{background:#353a40;border-bottom-color:var(--red);}
.mat-photo{width:100%;height:220px;object-fit:cover;margin-bottom:26px;border:1px solid var(--border);}
.mat-badge{display:inline-block;font-size:0.65rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;padding:4px 12px;margin-bottom:14px;width:fit-content;}
.mat-badge.std{background:rgba(255,255,255,0.06);color:var(--silver);border:1px solid var(--border);}
.mat-badge.biz{background:var(--red3);color:var(--red);border:1px solid rgba(212,43,43,0.4);}
.mat-name{font-family:'Anton',sans-serif;font-size:2.6rem;letter-spacing:0.04em;color:var(--white);margin-bottom:6px;}
.mat-brand{font-size:0.72rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--red);margin-bottom:14px;}
.mat-life{font-family:'Anton',sans-serif;font-size:4.5rem;line-height:1;color:var(--red);}
.mat-life-lbl{font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;}
.mat-desc{font-size:1.02rem;line-height:1.8;color:var(--silver);flex:1;}
.mat-guar{margin-top:16px;font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--white);background:var(--red);padding:9px 18px;width:fit-content;}

/* REVIEWS */
#reviews{background:var(--bg2);border-top:1px solid var(--border);}
.reviews-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border);}
.rev-card{background:var(--card);padding:40px;transition:background 0.3s;}
.rev-card:hover{background:#353a40;}
.rev-q{font-family:'Anton',sans-serif;font-size:4rem;color:var(--red);opacity:0.3;line-height:1;margin-bottom:-6px;}
.rev-text{font-size:1.05rem;line-height:1.85;color:var(--off);font-style:italic;margin-bottom:28px;font-weight:400;}
.rev-author{display:flex;align-items:center;gap:14px;padding-top:18px;border-top:1px solid var(--border);}
.rev-avatar{width:56px;height:56px;border-radius:50%;overflow:hidden;border:2px solid var(--red);flex-shrink:0;}
.rev-avatar img{width:100%;height:100%;object-fit:cover;}
.rev-name{font-size:1rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--white);}
.rev-stars{color:var(--red);font-size:0.85rem;letter-spacing:3px;margin-top:4px;}

/* FAQ */
#faq{background:var(--bg);border-top:1px solid var(--border);}
.faq-list{max-width:960px;}
.faq-item{border-bottom:1px solid var(--border);}
.faq-q{
  width:100%;background:none;border:none;color:var(--white);
  font-family:'Montserrat',sans-serif;font-size:1.12rem;font-weight:600;letter-spacing:0.03em;
  text-align:left;padding:26px 0;cursor:pointer;
  display:flex;justify-content:space-between;align-items:center;gap:20px;transition:color 0.2s;
}
.faq-q:hover{color:var(--red);}
.faq-q.active{color:var(--red);}
.faq-toggle{
  width:30px;height:30px;border:2px solid var(--red);color:var(--red);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  font-size:1.3rem;font-family:'Montserrat',sans-serif;transition:transform 0.3s;
  background:transparent;line-height:1;
}
.faq-q.active .faq-toggle{transform:rotate(45deg);}
.faq-ans{max-height:0;overflow:hidden;transition:max-height 0.4s ease;}
.faq-ans.open{max-height:500px;}
.faq-inner{padding:0 0 26px;font-size:1.05rem;line-height:1.9;color:var(--silver);}
.faq-inner ul{list-style:none;margin-top:12px;}
.faq-inner ul li::before{content:'—';color:var(--red);margin-right:10px;}

/* FOOTER */
footer{background:#111316;border-top:2px solid var(--red);padding:52px 80px;display:flex;justify-content:space-between;align-items:center;}
.foot-logo{font-family:'Anton',sans-serif;font-size:1.7rem;letter-spacing:0.12em;color:var(--white);}
.foot-logo em{color:var(--red);font-style:normal;}
.foot-copy{font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);}

.reveal{opacity:0;transform:translateY(26px);transition:opacity 0.65s ease,transform 0.65s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}

@media(max-width:900px){
  #hero{grid-template-columns:1fr;}
  .hero-right{height:60vw;}
  .hero-left{padding:72px 24px 52px;}
  section{padding:64px 24px;}
  .services-grid,.mat-grid,.reviews-grid{grid-template-columns:1fr;}
  footer{flex-direction:column;gap:16px;text-align:center;padding:40px 24px;}
  nav{padding:0 20px;}
  .nav-links a{font-size:0.72rem;padding:6px 10px;}
  .call-banner{min-width:260px;font-size:1.6rem;padding:18px 36px;}
}
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Мягкая<em>Кровля</em></div>
