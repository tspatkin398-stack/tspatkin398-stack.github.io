<!-- MATERIALS -->
<section id="materials">
  <div class="sec-label">Что я использую</div>
  <h2 class="sec-title">Материалы</h2>

  <div class="brand-strip reveal">
    <div class="brand-sq">ТН</div>
    <div>
      <div class="brand-title">Технониколь</div>
      <div class="brand-sub">Ведущий производитель · Линейки «Бизнес» и «Стандарт»</div>
    </div>
  </div>

  <div class="roll-scene" id="rollScene">
    <svg class="roll-svg" viewBox="0 0 1200 220" preserveAspectRatio="xMidYMid meet">
      <defs>
        <linearGradient id="mG" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" style="stop-color:#484f58"/>
          <stop offset="50%" style="stop-color:#2a2e33"/>
